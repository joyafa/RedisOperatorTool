{
  "name": "redis-operator",
  "version": "1.0.0",
  "description": "Redis Operator - A lightweight Redis data management tool",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "png-to-ico": "^3.0.2"
  },
  "build": {
    "appId": "com.redisoperator.app",
    "productName": "Redis Operator",
    "directories": {
      "output": "build-20260710"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "logger.js",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "server.js",
        "to": "."
      },
      {
        "from": "logger.js",
        "to": "."
      },
      {
        "from": "public",
        "to": "public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Redis-Operator-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Redis Operator"
    },
    "portable": {
      "artifactName": "Redis-Operator-Portable-${version}.${ext}",
      "requestExecutionLevel": "user",
      "unpackDirName": "Redis Operator"
    }
  }
}
